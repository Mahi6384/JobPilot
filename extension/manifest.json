{
  "manifest_version": 3,
  "name": "JobPilot Auto Apply",
  "version": "3.0.0",
  "description": "Automatically apply to matched jobs on Naukri and LinkedIn with smart form filling",

  "permissions": ["storage", "tabs", "activeTab", "scripting", "alarms"],

  "host_permissions": [
    "http://localhost:5000/*",
    "https://jobpilot-production-3ba1.up.railway.app/*",
    "http://127.0.0.1/*",
    "*://www.naukri.com/*",
    "*://naukri.com/*",
    "*://www.linkedin.com/*",
    "*://in.linkedin.com/*",
    "*://linkedin.com/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "action": {
    "default_popup": "popup/popup.html"
  },

  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "https://jobpilot-wheat.vercel.app/*"
    ]
  },

  "content_scripts": [
    {
      "matches": [
        "*://www.linkedin.com/*",
        "*://in.linkedin.com/*",
        "*://linkedin.com/*"
      ],
      "js": ["content-scripts/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "https://jobpilot-wheat.vercel.app/*"
      ],
      "js": ["content-scripts/bridge.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "utils/dom.js",
        "utils/formFiller.js",
        "content-scripts/naukri.js"
      ],
      "matches": [
        "*://www.naukri.com/*",
        "*://naukri.com/*",
        "*://www.linkedin.com/*",
        "*://in.linkedin.com/*",
        "*://linkedin.com/*"
      ]
    }
  ]
}
