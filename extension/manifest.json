{
  "manifest_version": 3,
  "name": "JobPilot Auto Apply",
  "version": "1.0.0",
  "description": "Automatically apply to matched jobs with one click",

  "permissions": ["storage", "tabs", "activeTab", "scripting"],

  "host_permissions": ["*://www.naukri.com/*", "*://www.linkedin.com/*"],

  "background": {
    "service_worker": "background/background.js"
  },

  "action": {
    "default_popup": "popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": ["*://www.naukri.com/*"],
      "js": ["content-scripts/common.js"],
      "run_at": "document_idle"
    }
  ]
}
