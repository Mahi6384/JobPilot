{
  "manifest_version": 3,
  "name": "JobPilot Auto Apply",
  "version": "1.0.0",
  "description": "Automatically apply to matched jobs with one click",

  "permissions": ["storage", "tabs", "activeTab", "scripting"],

  "host_permissions": [
    "*://www.naukri.com/*",
    "*://naukri.com/*",
    "*://www.linkedin.com/*"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "action": {
    "default_popup": "popup/popup.html"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "https://jobpilot-wheat.vercel.app/*"
    ]
  },
  "content_scripts": [
    {
      "matches": ["*://www.naukri.com/*"],
      "js": ["content-scripts/common.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.linkedin.com/*"],
      "js": ["content-scripts/common.js", "content-scripts/linkedin.js"],
      "run_at": "document_idle"
    }
  ]
}
